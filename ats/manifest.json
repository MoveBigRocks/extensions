{
  "schemaVersion": 1,
  "slug": "ats",
  "name": "Applicant Tracking",
  "version": "0.8.24",
  "publisher": "DemandOps",
  "kind": "product",
  "scope": "workspace",
  "risk": "standard",
  "runtimeClass": "service_backed",
  "storageClass": "owned_schema",
  "schema": {
    "name": "ext_demandops_ats",
    "packageKey": "demandops/ats",
    "targetVersion": "000001",
    "migrationEngine": "postgres_sql"
  },
  "runtime": {
    "protocol": "unix_socket_http",
    "ociReference": "ghcr.io/movebigrocks/mbr-ext-ats-runtime:v0.8.24",
    "digest": "sha256:pending"
  },
  "description": "Publish vacancies, run a careers site, intake candidate applications, and manage applicant stages on Move Big Rocks cases, contacts, queues, forms, attachments, tags, automations, and ATS-owned recruiting state.",
  "workspacePlan": {
    "mode": "provision_dedicated_workspace",
    "name": "Hiring",
    "slug": "hiring",
    "description": "Dedicated workspace for recruiting operations."
  },
  "permissions": [
    "case:read",
    "case:write",
    "contact:read",
    "contact:write",
    "attachment:read",
    "attachment:write",
    "form:write",
    "automation:write"
  ],
  "queues": [
    {
      "slug": "general-applications",
      "name": "General Applications",
      "description": "Default queue for incoming applications before they are moved into a job-specific bucket."
    },
    {
      "slug": "talent-pool",
      "name": "Talent Pool",
      "description": "Reusable pool for promising candidates who are not tied to one role."
    }
  ],
  "forms": [
    {
      "slug": "job-application",
      "name": "Job Application",
      "description": "Public form used by the careers site to create candidate cases.",
      "status": "active",
      "isPublic": true,
      "requiresAuth": false,
      "allowMultiple": true,
      "collectEmail": true,
      "autoCreateCase": true,
      "autoCasePriority": "normal",
      "autoCaseType": "web",
      "autoTags": [
        "ats",
        "candidate",
        "applied"
      ],
      "submissionMessage": "Thanks for applying. We have your application and will follow up by email.",
      "theme": "ats-careers",
      "schema": {
        "type": "object",
        "required": [
          "full_name",
          "email",
          "role_slug"
        ],
        "properties": {
          "full_name": {
            "type": "string",
            "title": "Full Name"
          },
          "email": {
            "type": "string",
            "title": "Email",
            "format": "email"
          },
          "phone": {
            "type": "string",
            "title": "Phone"
          },
          "location": {
            "type": "string",
            "title": "Location"
          },
          "role_slug": {
            "type": "string",
            "title": "Role"
          },
          "linkedin_url": {
            "type": "string",
            "title": "LinkedIn URL"
          },
          "portfolio_url": {
            "type": "string",
            "title": "Portfolio URL"
          },
          "resume_attachment_id": {
            "type": "string",
            "title": "Resume Attachment ID",
            "description": "Optional shared attachment ID for the candidate resume or CV."
          },
          "cover_note": {
            "type": "string",
            "title": "Why are you interested?"
          }
        }
      },
      "uiSchema": {
        "order": [
          "full_name",
          "email",
          "phone",
          "location",
          "role_slug",
          "linkedin_url",
          "portfolio_url",
          "resume_attachment_id",
          "cover_note"
        ]
      },
      "validationRules": {
        "maxLength": {
          "cover_note": 4000
        }
      }
    }
  ],
  "automationRules": [
    {
      "key": "ext.demandops.ats.application_received_tag",
      "title": "ATS application form",
      "description": "Add a review tag to new ATS cases created through the application form.",
      "isActive": true,
      "priority": 50,
      "maxExecutionsPerHour": 500,
      "maxExecutionsPerDay": 5000,
      "conditions": {
        "operator": "and",
        "conditions": [
          {
            "type": "event",
            "field": "trigger",
            "operator": "equals",
            "value": "case_created"
          },
          {
            "type": "field",
            "field": "form_slug",
            "operator": "equals",
            "value": "job-application"
          }
        ]
      },
      "actions": {
        "actions": [
          {
            "type": "add_tag",
            "value": "ats-review"
          }
        ]
      }
    },
    {
      "key": "ext.demandops.ats.stage_change_followup",
      "title": "ATS stage changes",
      "description": "Tag candidate cases when ATS-owned stage transitions require recruiter follow-up.",
      "isActive": true,
      "priority": 55,
      "maxExecutionsPerHour": 500,
      "maxExecutionsPerDay": 5000,
      "conditions": {
        "operator": "and",
        "conditions": [
          {
            "type": "event",
            "field": "trigger",
            "operator": "equals",
            "value": "ats_application_stage_changed"
          }
        ]
      },
      "actions": {
        "actions": [
          {
            "type": "add_tag",
            "value": "ats-stage-review"
          }
        ]
      }
    }
  ],
  "artifactSurfaces": [
    {
      "name": "website",
      "description": "Published public careers site content for the ATS extension.",
      "seedAssetPath": "templates/careers"
    },
    {
      "name": "admin-ui",
      "description": "Published admin experience content for the ATS extension.",
      "seedAssetPath": "templates/admin"
    }
  ],
  "endpoints": [
    {
      "name": "careers-home",
      "class": "public_page",
      "mountPath": "/careers",
      "methods": [
        "GET"
      ],
      "auth": "public",
      "workspaceBinding": "none",
      "artifactSurface": "website",
      "artifactPath": "index.html"
    },
    {
      "name": "careers-apply",
      "class": "public_page",
      "mountPath": "/careers/apply",
      "methods": [
        "GET"
      ],
      "auth": "public",
      "workspaceBinding": "none",
      "artifactSurface": "website",
      "artifactPath": "apply.html"
    },
    {
      "name": "ats-public-application-submit",
      "class": "public_ingest",
      "mountPath": "/careers/applications",
      "methods": [
        "POST"
      ],
      "auth": "public",
      "workspaceBinding": "none",
      "serviceTarget": "ats.public.submit",
      "contentTypes": [
        "application/json",
        "application/x-www-form-urlencoded",
        "multipart/form-data"
      ],
      "maxBodyBytes": 131072,
      "rateLimitPerMinute": 60
    },
    {
      "name": "ats-admin-dashboard",
      "class": "admin_page",
      "mountPath": "/extensions/ats",
      "methods": [
        "GET"
      ],
      "auth": "session",
      "workspaceBinding": "workspace_from_session",
      "artifactSurface": "admin-ui",
      "artifactPath": "dashboard.html"
    },
    {
      "name": "ats-api-jobs",
      "class": "extension_api",
      "mountPath": "/extensions/ats/api/jobs",
      "methods": [
        "GET",
        "POST"
      ],
      "auth": "session",
      "workspaceBinding": "workspace_from_session",
      "serviceTarget": "ats.api.jobs"
    },
    {
      "name": "ats-api-job-publish",
      "class": "admin_action",
      "mountPath": "/extensions/ats/api/jobs/:id/publish",
      "methods": [
        "POST"
      ],
      "auth": "session",
      "workspaceBinding": "workspace_from_session",
      "serviceTarget": "ats.api.jobs.publish"
    },
    {
      "name": "ats-api-job-close",
      "class": "admin_action",
      "mountPath": "/extensions/ats/api/jobs/:id/close",
      "methods": [
        "POST"
      ],
      "auth": "session",
      "workspaceBinding": "workspace_from_session",
      "serviceTarget": "ats.api.jobs.close"
    },
    {
      "name": "ats-api-job-reopen",
      "class": "admin_action",
      "mountPath": "/extensions/ats/api/jobs/:id/reopen",
      "methods": [
        "POST"
      ],
      "auth": "session",
      "workspaceBinding": "workspace_from_session",
      "serviceTarget": "ats.api.jobs.reopen"
    },
    {
      "name": "ats-api-job-applications",
      "class": "extension_api",
      "mountPath": "/extensions/ats/api/jobs/:id/applications",
      "methods": [
        "GET"
      ],
      "auth": "session",
      "workspaceBinding": "workspace_from_session",
      "serviceTarget": "ats.api.jobs.applications"
    },
    {
      "name": "ats-api-workspace-defaults",
      "class": "extension_api",
      "mountPath": "/extensions/ats/api/defaults",
      "methods": [
        "GET"
      ],
      "auth": "session",
      "workspaceBinding": "workspace_from_session",
      "serviceTarget": "ats.api.defaults"
    },
    {
      "name": "ats-api-application-stage",
      "class": "admin_action",
      "mountPath": "/extensions/ats/api/applications/:id/stage",
      "methods": [
        "POST"
      ],
      "auth": "session",
      "workspaceBinding": "workspace_from_session",
      "serviceTarget": "ats.api.applications.stage"
    },
    {
      "name": "ats-api-application-notes",
      "class": "admin_action",
      "mountPath": "/extensions/ats/api/applications/:id/notes",
      "methods": [
        "POST"
      ],
      "auth": "session",
      "workspaceBinding": "workspace_from_session",
      "serviceTarget": "ats.api.applications.notes"
    },
    {
      "name": "ats-runtime-health",
      "class": "health",
      "mountPath": "/extensions/ats/health",
      "methods": [
        "GET",
        "HEAD"
      ],
      "auth": "internal_only",
      "workspaceBinding": "instance_scoped",
      "serviceTarget": "ats.runtime.health"
    }
  ],
  "adminNavigation": [
    {
      "name": "ats-dashboard",
      "section": "Extensions",
      "title": "ATS",
      "icon": "briefcase-business",
      "endpoint": "ats-admin-dashboard",
      "activePage": "ats"
    }
  ],
  "dashboardWidgets": [
    {
      "name": "ats-overview",
      "title": "ATS Workspace",
      "description": "Open the live hiring dashboard, workspace directory, and candidate operations.",
      "icon": "briefcase-business",
      "endpoint": "ats-admin-dashboard"
    }
  ],
  "events": {
    "publishes": [
      {
        "type": "ext.demandops.ats.job_posting_published",
        "description": "A job posting was published to the careers site.",
        "schemaVersion": 1
      },
      {
        "type": "ext.demandops.ats.application_received",
        "description": "A candidate application was accepted by the ATS form flow.",
        "schemaVersion": 1
      }
    ],
    "subscribes": [
      "form.submitted",
      "case.created",
      "case.status_changed"
    ]
  },
  "commands": [
    {
      "name": "ats.jobs.create",
      "description": "Create a job, its recruiting queue, and ATS workspace defaults."
    },
    {
      "name": "ats.jobs.publish",
      "description": "Publish a job and expose it on the careers site."
    },
    {
      "name": "ats.jobs.close",
      "description": "Close a published job and hide it from the careers site."
    },
    {
      "name": "ats.jobs.reopen",
      "description": "Reopen a closed job and resume intake."
    },
    {
      "name": "ats.candidates.stage.set",
      "description": "Move a candidate case through the configured ATS pipeline."
    },
    {
      "name": "ats.candidates.note.add",
      "description": "Add a recruiter note to an ATS application record."
    }
  ],
  "agentSkills": [
    {
      "name": "publish-job",
      "description": "Guide an agent through drafting, reviewing, and publishing a job in the ATS extension.",
      "assetPath": "agent-skills/publish-job.md"
    },
    {
      "name": "review-candidates",
      "description": "Guide an agent through triaging incoming candidate cases and updating ATS stages safely.",
      "assetPath": "agent-skills/review-candidates.md"
    }
  ],
  "customizableAssets": [
    "templates/careers/index.html",
    "templates/careers/apply.html",
    "templates/admin/dashboard.html"
  ],
  "defaultConfig": {
    "brand": "Acme",
    "siteTitle": "Careers at Acme",
    "primaryColor": "#0f766e",
    "resumeField": "resume_attachment_id",
    "vacancyStatuses": [
      "draft",
      "open",
      "paused",
      "closed",
      "archived"
    ],
    "stages": [
      "applied",
      "screening",
      "interview",
      "offer",
      "hired",
      "rejected"
    ]
  }
}
