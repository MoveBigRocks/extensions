{
  "schemaVersion": 1,
  "slug": "ats",
  "name": "Applicant Tracking",
  "version": "0.8.30",
  "publisher": "DemandOps",
  "kind": "product",
  "scope": "workspace",
  "risk": "standard",
  "runtimeClass": "service_backed",
  "storageClass": "owned_schema",
  "schema": {
    "name": "ext_demandops_ats",
    "packageKey": "demandops/ats",
    "targetVersion": "000006",
    "migrationEngine": "postgres_sql"
  },
  "runtime": {
    "protocol": "unix_socket_http",
    "ociReference": "ghcr.io/movebigrocks/mbr-ext-ats-runtime:v0.8.30",
    "digest": "sha256:pending"
  },
  "description": "Set up a branded careers site, publish jobs, intake candidate applications, and manage applicant stages on Move Big Rocks cases, contacts, queues, attachments, tags, automations, and ATS-owned recruiting state.",
  "workspacePlan": {
    "mode": "provision_dedicated_workspace",
    "name": "Hiring",
    "slug": "hiring",
    "description": "Dedicated workspace for recruiting operations."
  },
  "permissions": [
    "case:read",
    "case:write",
    "contact:read",
    "contact:write",
    "attachment:read",
    "attachment:write",
    "queue:read",
    "queue:write",
    "automation:write"
  ],
  "queues": [
    {
      "slug": "general-applications",
      "name": "General Applications",
      "description": "Default queue for incoming applications before they are moved into a job-specific bucket."
    },
    {
      "slug": "talent-pool",
      "name": "Talent Pool",
      "description": "Reusable pool for promising candidates who are not tied to one role."
    }
  ],
  "automationRules": [
    {
      "key": "ext.demandops.ats.application_received_tag",
      "title": "ATS application intake",
      "description": "Add a review tag to new ATS candidate cases created through the ATS-native intake flow.",
      "isActive": true,
      "priority": 50,
      "maxExecutionsPerHour": 500,
      "maxExecutionsPerDay": 5000,
      "conditions": {
        "operator": "and",
        "conditions": [
          {
            "type": "event",
            "field": "trigger",
            "operator": "equals",
            "value": "case_created"
          },
          {
            "type": "field",
            "field": "ats_application_source_kind",
            "operator": "equals",
            "value": "ats_public"
          }
        ]
      },
      "actions": {
        "actions": [
          {
            "type": "add_tag",
            "value": "ats-review"
          }
        ]
      }
    },
    {
      "key": "ext.demandops.ats.stage_change_followup",
      "title": "ATS stage changes",
      "description": "Tag candidate cases when ATS-owned stage transitions require recruiter follow-up.",
      "isActive": true,
      "priority": 55,
      "maxExecutionsPerHour": 500,
      "maxExecutionsPerDay": 5000,
      "conditions": {
        "operator": "and",
        "conditions": [
          {
            "type": "event",
            "field": "trigger",
            "operator": "equals",
            "value": "ats_application_stage_changed"
          }
        ]
      },
      "actions": {
        "actions": [
          {
            "type": "add_tag",
            "value": "ats-stage-review"
          }
        ]
      }
    }
  ],
  "artifactSurfaces": [
    {
      "name": "website",
      "description": "Published public careers site content for the ATS extension.",
      "seedAssetPath": "templates/careers"
    },
    {
      "name": "admin-ui",
      "description": "Published admin experience content for the ATS extension.",
      "seedAssetPath": "templates/admin"
    }
  ],
  "publicRoutes": [
    {
      "pathPrefix": "/careers",
      "artifactSurface": "website",
      "artifactPath": "site"
    }
  ],
  "endpoints": [
    {
      "name": "ats-public-application-submit",
      "class": "public_ingest",
      "mountPath": "/careers/applications",
      "methods": [
        "POST"
      ],
      "auth": "public",
      "workspaceBinding": "none",
      "serviceTarget": "ats.public.submit",
      "contentTypes": [
        "application/json",
        "application/x-www-form-urlencoded",
        "multipart/form-data"
      ],
      "maxBodyBytes": 131072,
      "rateLimitPerMinute": 60
    },
    {
      "name": "ats-public-attachment-upload",
      "class": "public_ingest",
      "mountPath": "/careers/attachments",
      "methods": [
        "POST"
      ],
      "auth": "public",
      "workspaceBinding": "none",
      "serviceTarget": "ats.public.attachments",
      "contentTypes": [
        "multipart/form-data"
      ],
      "maxBodyBytes": 26214400,
      "rateLimitPerMinute": 20
    },
    {
      "name": "ats-admin-dashboard",
      "class": "admin_page",
      "mountPath": "/extensions/ats",
      "methods": [
